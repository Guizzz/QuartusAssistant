{
  "scopeName": "source.vhdl",
  "name": "VHDL",

  "foldingStartMarker": "(?i)^\\s*(entity|architecture|package|process|case|record|loop|if|generate)\\b",
  "foldingStopMarker": "(?i)^\\s*end\\b.*;",

  "patterns": [
    { "include": "#comments" },
    { "include": "#todo" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#library_clause" },
    { "include": "#use_clause" },
    { "include": "#entity_declaration" },
    { "include": "#architecture_declaration" },
    { "include": "#package_declaration" },
    { "include": "#component_declaration" },
    { "include": "#entity_instantiation" },
    { "include": "#instance_label" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#signals" },
    { "include": "#constants" },
    { "include": "#variables" },
    { "include": "#generics_ports" },
    { "include": "#functions" },
    { "include": "#attributes" },
    { "include": "#operators" },
    { "include": "#parentheses" },
    { "include": "#parameters" }
  ],

  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.vhdl",
          "match": "--.*$"
        }
      ]
    },

    "todo": {
      "patterns": [
        {
          "name": "keyword.annotation.todo.vhdl",
          "match": "\\b(TODO|FIXME|BUG|NOTE|HACK|WARNING)\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.vhdl",
          "match": "\"(?:\\\\.|[^\"])*\""
        },
        {
          "name": "string.quoted.single.vhdl",
          "match": "'.'"
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.decimal.vhdl",
          "match": "\\b\\d+(?:_\\d+)*(?:\\.\\d+)?\\b"
        },
        {
          "name": "constant.numeric.hex.vhdl",
          "match": "(?i)x\"[0-9a-f_]+\""
        },
        {
          "name": "constant.numeric.binary.vhdl",
          "match": "(?i)b\"[01_]+\""
        },
        {
          "name": "constant.numeric.octal.vhdl",
          "match": "(?i)o\"[0-7_]+\""
        }
      ]
    },

    "library_clause": {
      "patterns": [
        {
          "match": "(?i)\\blibrary\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.library.vhdl"
            },
            "1": {
              "name": "entity.name.namespace.vhdl"
            }
          }
        }
      ]
    },

    "use_clause": {
      "patterns": [
        {
          "match": "(?i)\\buse\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.use.vhdl"
            },
            "1": {
              "name": "entity.name.namespace.vhdl"
            },
            "2": {
              "name": "entity.name.package.vhdl"
            },
            "3": {
              "name": "keyword.control.vhdl"
            }
          }
        }
      ]
    },

    "entity_declaration": {
      "patterns": [
        {
          "match": "(?i)\\bentity\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.entity.vhdl"
            },
            "1": {
              "name": "entity.name.type.vhdl"
            }
          }
        }
      ]
    },

    "architecture_declaration": {
      "patterns": [
        {
          "match": "(?i)\\barchitecture\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s+of\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.architecture.vhdl"
            },
            "1": {
              "name": "entity.name.architecture.vhdl"
            },
            "2": {
              "name": "entity.name.type.vhdl"
            }
          }
        }
      ]
    },

    "package_declaration": {
      "patterns": [
        {
          "match": "(?i)\\bpackage(?:\\s+body)?\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.package.vhdl"
            },
            "1": {
              "name": "entity.name.package.vhdl"
            }
          }
        }
      ]
    },

    "component_declaration": {
      "patterns": [
        {
          "match": "(?i)\\bcomponent\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.component.vhdl"
            },
            "1": {
              "name": "entity.name.component.vhdl"
            }
          }
        }
      ]
    },

    "entity_instantiation": {
      "patterns": [
        {
          "match": "(?i)\\bentity\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\.([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": {
              "name": "entity.name.namespace.vhdl"
            },
            "2": {
              "name": "entity.name.type.vhdl"
            }
          }
        }
      ]
    },

    "instance_label": {
      "patterns": [
        {
          "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
          "captures": {
            "1": {
              "name": "entity.name.function.vhdl"
            }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.vhdl",
          "match": "(?i)\\b(entity|architecture|signal|process|begin|end|is|port|generic|map|if|then|else|elsif|case|when|loop|for|while|generate|package|body|component|library|use|constant|type|subtype|record|array|function|procedure|variable|wait|until|downto|to|others|in|out|inout|buffer|report|assert|severity|next|exit|return|shared|file|open|after|transport|reject|null|with|select)\\b"
        }
      ]
    },

    "types": {
      "patterns": [
        {
          "name": "storage.type.vhdl",
          "match": "(?i)\\b(std_logic|std_logic_vector|unsigned|signed|integer|natural|positive|boolean|string|character|real|time|bit|bit_vector|ufixed|sfixed)\\b"
        },
        {
          "name": "constant.language.time.vhdl",
          "match": "(?i)\\b(fs|ps|ns|us|ms|sec|min|hr)\\b"
        },
        {
          "name": "constant.language.boolean.vhdl",
          "match": "(?i)\\b(true|false)\\b"
        }
      ]
    },

    "signals": {
      "patterns": [
        {
          "match": "(?i)\\bsignal\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.signal.vhdl"
            },
            "1": {
              "name": "variable.other.signal.vhdl"
            }
          }
        }
      ]
    },

    "variables": {
      "patterns": [
        {
          "match": "(?i)\\bvariable\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.variable.vhdl"
            },
            "1": {
              "name": "variable.other.variable.vhdl"
            }
          }
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "match": "(?i)\\bconstant\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "0": {
              "name": "keyword.control.constant.vhdl"
            },
            "1": {
              "name": "entity.name.constant.vhdl"
            }
          }
        }
      ]
    },

    "generics_ports": {
      "patterns": [
        {
          "match": "(?i)^\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:\\s*(in|out|inout|buffer)?",
          "captures": {
            "1": {
              "name": "variable.parameter.port.vhdl"
            },
            "2": {
              "name": "storage.modifier.direction.vhdl"
            }
          }
        }
      ]
    },

    "functions": {
      "patterns": [
        {
          "name": "support.function.vhdl",
          "match": "(?i)\\b(rising_edge|falling_edge|resize|shift_left|shift_right|rotate_left|rotate_right|to_integer|to_unsigned|to_signed|std_match|conv_integer|conv_std_logic_vector|abs|max|min)\\b"
        }
      ]
    },

    "attributes": {
      "patterns": [
        {
          "match": "'(event|length|range|left|right|high|low|ascending|image|value)",
          "captures": {
            "1": {
              "name": "variable.language.attribute.vhdl"
            }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.vhdl",
          "match": "(<=|:=|=>)"
        },
        {
          "name": "keyword.operator.relational.vhdl",
          "match": "(=|/=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.arithmetic.vhdl",
          "match": "(\\+|-|\\*|/|\\*\\*|&)"
        },
        {
          "name": "keyword.operator.logic.vhdl",
          "match": "(?i)\\b(and|or|xor|xnor|nand|nor|not|mod|rem)\\b"
        }
      ]
    },

    "parentheses": {
      "patterns": [
        {
          "name": "punctuation.section.parens.begin.vhdl",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.vhdl",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.vhdl",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.vhdl",
          "match": "\\]"
        }
      ]
    },

    "parameters": {
      "patterns": [
        {
          "name": "entity.name.parameter.vhdl",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(?==>)",
          "captures": {
            "1": {
              "name": "variable.parameter.mapping.vhdl"
            }
          }
        }
      ]
    }
  }
}
