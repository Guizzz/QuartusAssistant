{
  "name": "quartus-assistant",
  "displayName": "Quartus Assistant",
  "description": "",
  "version": "0.4.1",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "quartus-assistant.build",
        "title": "Quartus: Build"
      },
      {
        "command": "quartus-assistant.setQuartusPath",
        "title": "Quartus: Set Quartus Path"
      },
      {
        "command": "quartus-assistant.flash",
        "title": "Quartus: Flash"
      },
      {
        "command": "quartus-assistant.generateDo",
        "title": "Quartus: Generate QuestaSim DO"
      }
    ],
    "languages": [
      {
        "id": "qsf",
        "extensions": [
          ".qsf"
        ],
        "aliases": [
          "QSF",
          "Quartus Settings File"
        ]
      },
      {
        "id": "qpf",
        "extensions": [
          ".qpf"
        ],
        "aliases": [
          "QPF",
          "Quartus Project File"
        ]
      },
      {
        "id": "questasim-do",
        "extensions": [
          ".do"
        ],
        "aliases": [
          "QuestaSim DO"
        ]
      }
    ],
    "configuration": {
      "title": "Quartus",
      "properties": {
        "maxv.quartusPath": {
          "type": "string",
          "default": "C:\\altera_lite\\25.1std",
          "description": "Path to Quartus installation folder (e.g. C:\\intelFPGA\\25.1std\\quartus)"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "myExtension",
          "title": "Quartus Assistant",
          "icon": "$(chip)"
        }
      ]
    },
    "views": {
      "myExtension": [
        {
          "id": "quartus-assistant-view",
          "name": "Quartus Assistant Panel",
          "icon": "$(chip)"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Guizzz/QuartusAssistant.git"
  }
}
